{
  "name": "depctl",
  "version": "0.1.0",
  "private": true,
  "description": "Per-server webhook service for Docker Compose deployments",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --exec ts-node src/index.ts",
    "build": "tsc",
    "build:cli": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/depctl-cli.cjs --format=cjs --external:readline/promises",
    "start": "node dist/index.js webhook",
    "start:webhook": "node dist/index.js webhook",
    "start:admin": "node dist/index.js admin",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"docs/**/*.md\" \"task/**/*.md\"",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "check:branding": "! grep -rn 'deployctl' src/ docs/ README.md --include='*.ts' --include='*.md'",
    "lint:all": "npm run lint && npm run check:branding"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "bullmq": "^5.58.5",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "js-yaml": "^4.1.0",
    "resend": "^4.1.2",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
